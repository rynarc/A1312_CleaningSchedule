# Copy this file to .env and fill in the values from your Supabase project
# (Project Settings → API). Both values are meant to be public — the anon
# key is safe to ship in a frontend bundle; access control is via Row Level
# Security policies on the Supabase table, not by keeping this key secret.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
